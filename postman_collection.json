            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tech Conference\",\n  \"description\": \"MERN Stack Meetup\",\n  \"date\": \"2026-04-10 10:00:00\",\n  \"capacity\": 100\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          }
        }
      ]
    },
